{
  "name": "paisatrack",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/elements": "^2.9.20",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-intent-launcher": "~13.0.8",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.3",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "sms-listener": "file:./modules/sms-listener",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "node scripts/prepare-ios-native.js --prebuild && expo run:ios",
    "ios:release": "node scripts/prepare-ios-native.js --prebuild && expo run:ios --configuration Release",
    "ios:prepare": "node scripts/prepare-ios-native.js --prebuild",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:ios:clean": "expo prebuild --platform ios --clean",
    "pod-install": "node scripts/prepare-ios-native.js && cd ios && pod install",
    "web": "expo start --web",
    "build:apk": "cd android && ./gradlew assembleRelease",
    "build:apk:debug": "cd android && ./gradlew assembleDebug",
    "build:ios:sim": "npm run ios:release",
    "generate:icons": "node scripts/generate-paisatrack-icons.mjs",
    "postinstall": "node scripts/prepare-ios-native.js"
  },
  "private": true,
  "overrides": {
    "expo-font": "~14.0.12"
  }
}
